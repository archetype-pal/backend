# Local/CI test environment. Credentials are random and must be regenerated
# per environment — never reuse in production. The password here MUST match
# POSTGRES_PASSWORD in api/compose.yaml so the Postgres container accepts it.

SECRET_KEY="test-only-F_2WlLpYoTNaTc1ae_ucqmrH_M5yGPoC"
DEBUG=true
SEARCH_AUTO_REINDEX=false
SEARCH_REINDEX_DEBOUNCE_SECONDS=10
SITE_NAME="Local test"

# Database
DATABASE_URL="postgresql://postgres:F_2WlLpYoTNaTc1ae_ucqmrH_M5yGPoC@postgres:5432/local"

# IIIF
# IIIF_HOST is the BROWSER-facing SIPI base (dev host port 8182), used to build
# IIIF URLs handed to the frontend.
IIIF_HOST=http://localhost:8182
# UPLOADS_SIPI_BASE_URL is the SERVER-side address the Celery worker uses for the
# post-conversion tile smoke test — it must reach SIPI over the compose network,
# not via the browser host port. Without this it falls back to IIIF_HOST
# (localhost), which the worker container can't reach, so every upload's tile
# check fails. In the infrastructure/prod stack, set this to the internal SIPI URL.
UPLOADS_SIPI_BASE_URL=http://image_server:1024

# CORS and Hosts
ALLOWED_HOSTS=localhost
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8000
SESSION_COOKIE_DOMAIN=
CSRF_COOKIE_DOMAIN=

# Choices
HISTORICAL_ITEM_TYPES="Agreement,Charter,Letter"
HISTORICAL_ITEM_HAIR_TYPES="FHFH,FHHF,HFFH,HFHF,Mixed"
REPOSITORY_TYPES="Library,Institution,Person,Online Resource"
CHARACTER_ITEM_TYPES="Majuscule Letter,Minuscule Letter,Numeral,Punctuation,Symbol,Accent"