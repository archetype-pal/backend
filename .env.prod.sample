# PostgreSQL service
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=local
POSTGRES_USER=postgres
POSTGRES_PASSWORD= # TODO CHANGE ME
PGDATA=/var/lib/postgresql/18/docker

# pgAdmin service
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

# Database
DATABASE_URL="postgresql://postgres:F_2WlLpYoTNaTc1ae_ucqmrH_M5yGPoC@postgres:5432/local"

# IIIF
IIIF_HOST=https://archetype-iiif.tetras-libre.fr

# CORS and Hosts
ALLOWED_HOSTS=https://archetype.tetras-libre.fr
CORS_ALLOWED_ORIGINS=https://archetype.tetras-libre.fr,https://archetype-api.tetras-libre.fr,http://frontend
CSRF_TRUSTED_ORIGINS=https://archetype.tetras-libre.fr,https://archetype-api.tetras-libre.fr,http://frontend
SESSION_COOKIE_DOMAIN=
CSRF_COOKIE_DOMAIN=

# Choices
